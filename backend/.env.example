# Local: copia este archivo a backend/.env si necesitas cambiar valores.
# Staging/production: define estas variables en el entorno del despliegue y no subas .env.
APP_APP_NAME=gym-routines-api
APP_ENVIRONMENT=local
APP_DATABASE_URL=postgresql+psycopg://gym_app:gym_app@localhost:5432/gym_app

# Cambiar obligatoriamente en staging/production. Staging/production fallan si queda este valor local.
APP_SECRET_KEY=local-development-secret-key-change-me

# Duraciones independientes de access y refresh tokens.
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_REFRESH_TOKEN_EXPIRE_DAYS=30

# Rate limiting auth MVP/local: memoria del proceso. En multiinstancia usar Redis o storage compartido.
APP_AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=5
APP_AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
APP_AUTH_REGISTER_RATE_LIMIT_ATTEMPTS=5
APP_AUTH_REGISTER_RATE_LIMIT_WINDOW_SECONDS=600

# IA. Default seguro: reglas internas. Ollama es local/gratis si lo instalas fuera del proyecto.
APP_AI_PROVIDER=internal
APP_AI_OLLAMA_BASE_URL=http://localhost:11434
APP_AI_OLLAMA_MODEL=llama3.2
APP_AI_TIMEOUT_SECONDS=20
APP_AI_EXTERNAL_DATA_ENABLED=false

# Local web/LAN. En staging/production, usar los origenes publicos reales del frontend.
APP_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006,http://192.168.1.44:8081,http://192.168.1.44:19006
